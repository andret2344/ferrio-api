{% extends 'base.html.twig' %}
{% block body %}
	{% set toolbar_html %}
		<div class="form-check form-switch mb-0">
			<input
					class="form-check-input"
					type="checkbox"
					id="hideDescribedHolidays"
					aria-checked="false">
			<label class="form-check-label text-light" for="hideDescribedHolidays">Hide described</label>
		</div>
	{% endset %}
	<main class='section-manage-main'>
		{% include 'components/topbar.html.twig' with {toolbar: toolbar_html} %}
		<div class='manage-content'>
			<h2 class='manage-page-title'>Holidays</h2>
			<div id="toast-container" class="toast-container position-fixed bottom-0 end-0 p-3"></div>
			{% include 'components/navigation.html.twig' with {'page': page, 'url': '/manage/create/%page%'} %}
			<div class='table-responsive'>
				<table class="table table-dark table-striped table-hover align-middle">
					<caption>Translations</caption>
					<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col" style='min-width: 142px'>Country</th>
						<th scope="col">+18</th>
						<th scope="col">Month</th>
						<th scope="col">Day</th>
						<th scope="col" class='w-25'>Name</th>
						<th scope="col" class='w-75'>Description</th>
						<th scope="col">Action</th>
					</tr>
					</thead>
					<tbody>
					{% for element in fixed_holidays %}
						{% set form_id = 'form-' ~ element.id %}
						<form id='{{ form_id }}' method='post'>
							<input type='hidden' name='action' value='update' form='{{ form_id }}'/>
							<input type='hidden' name='metadata_id' value='{{ element.id }}' form='{{ form_id }}'/>
							{{ form_widget(updateForms[element.id]._token) }}
						</form>
						<tr class='tr-holiday'>
							<th scope="row">{{ element.id }}</th>
							<td>
								{% if element.countryName %}
									{{ element.countryCode }} - {{ element.countryName }}
								{% else %}
									International
								{% endif %}
							</td>
							<td>
								<label for='{{ 'mature-' ~ element.id }}' class='d-none'>Mature content</label>
								<input
										id='{{ 'mature-' ~ element.id }}'
										class="w-100"
										type="checkbox"
										name="mature"
										form='{{ form_id }}'
										{{ (element.matureContent ? 'checked')|raw }}
								/>
							</td>
							<td>{{ element.month }}</td>
							<td>{{ element.day }}</td>
							<td>
								<label for='{{ 'name-' ~ element.id }}' class='d-none'>Name</label>
								<textarea
										style='min-height: 72px'
										name='name'
										class='w-100 manage-input'
										form='{{ form_id }}'
										id='{{ 'name-' ~ element.id }}'
								>{{ element.name }}</textarea>
							</td>
							<td>
								<label for='{{ 'description-' ~ element.id }}' class='d-none'>Description</label>
								<div class='d-flex align-items-center gap-1'>
									<textarea
											style='min-height: 72px'
											name='description'
											class='w-100 manage-input textarea-holiday-description'
											form='{{ form_id }}'
											id='{{ 'description-' ~ element.id }}'
									>{{ element.description }}</textarea>
									<button
											type='button'
											class='btn btn-sm btn-outline-light btn-generate-desc flex-shrink-0'
											title='Generate description with AI'
											data-target='{{ 'description-' ~ element.id }}'
											data-name-source='{{ 'name-' ~ element.id }}'
											data-month='{{ element.month }}'
											data-day='{{ element.day }}'
									><i class='bi bi-stars'></i></button>
								</div>
							</td>
							<td><button type='submit' form='{{ form_id }}' class='btn btn-sm btn-outline-light'><i class='bi bi-check-lg'></i></button></td>
						</tr>
					{% endfor %}
					</tbody>
				</table>
			</div>
			<form id='create' method='post'>
				<input type='hidden' name='action' value='create' form='create'/>
				{{ form_widget(createForm._token) }}
			</form>
			<div class='table-responsive'>
				<table class='table table-dark table-striped table-hover align-middle'>
					<caption>Adding</caption>
					<thead>
					<tr>
						<th scope="col">#</th>
						<th scope="col">Country</th>
						<th scope="col">+18</th>
						<th scope="col">Month</th>
						<th scope="col">Day</th>
						<th scope="col" class='w-25'>Name</th>
						<th scope="col" class='w-75'>Description</th>
						<th scope="col">Action</th>
					</tr>
					</thead>
					<tbody>
					<tr>
						<th scope="row">#</th>
						<td>
							<label for='country-create' class='d-none'>Country</label>
							<select
									id='country-create'
									class="form-select form-select-sm manage-input"
									name='country'
									form='create'
							>
								<option value='null' selected>International</option>
								{% for country in countries %}
									<option value='{{ country.isoCode }}'>{{ country.isoCode }}
										- {{ country.englishName }}</option>
								{% endfor %}
							</select>
						</td>
						<td>
							<label for="mature-create" class='d-none'>Mature content</label>
							<input
									id="mature-create"
									class="w-100"
									type="checkbox"
									name="mature"
									form='create'
							/>
						</td>
						<td>
							<label for='month-create' class='d-none'>Month</label>
							<input
									required
									type='number'
									max='12'
									min='1'
									name='month'
									form='create'
									id='month-create'
									class='manage-input'
							/>
						</td>
						<td>
							<label for='day-create' class='d-none'>Day</label>
							<input
									required
									type='number'
									max='31'
									min='1'
									name='day'
									form='create'
									id='day-create'
									class='manage-input'
							/>
						</td>
						<td>
							<label for='name-create' class='d-none'>Name</label>
							<textarea
									required
									style='min-height: 72px'
									name='name'
									class='w-100 manage-input'
									form='create'
									id='name-create'
							></textarea>
						</td>
						<td>
							<label for='description-create' class='d-none'>Description</label>
							<div class='d-flex align-items-center gap-1'>
								<textarea
										style='min-height: 72px'
										name='description'
										class='w-100 manage-input'
										form='create'
										id='description-create'
								></textarea>
								<button
										type='button'
										class='btn btn-sm btn-outline-light btn-generate-desc flex-shrink-0'
										title='Generate description with AI'
										data-target='description-create'
										data-name-source='name-create'
										data-month-source='month-create'
										data-day-source='day-create'
								><i class='bi bi-stars'></i></button>
							</div>
						</td>
						<td><button type='submit' form='create' class='btn btn-sm btn-outline-light'><i class='bi bi-plus-lg'></i></button></td>
					</tr>
					</tbody>
				</table>
			</div>
			{% include 'components/navigation.html.twig' with {'page': page, 'url': '/manage/create/%page%'} %}
		</div>
	</main>
	<script type='text/javascript'>
		document.addEventListener('DOMContentLoaded', () => {
		const hidingSwitch = document.querySelector('#hideDescribedHolidays');
		if (localStorage.getItem('hide') === 'true') {
			hidingSwitch.checked = true;
		}
		showOrHide(!!hidingSwitch.checked);
		hidingSwitch.addEventListener('change', () => {
			const checked = hidingSwitch.checked;
			localStorage.setItem('hide', JSON.stringify(checked));
			showOrHide(checked);
		});

		function showOrHide(checked) {
			document.querySelectorAll('.tr-holiday').forEach(element => {
				const value = element.querySelector('.textarea-holiday-description').value;
				if (value) {
					if (checked) {
						element.classList.add('d-none');
					} else {
						element.classList.remove('d-none');
					}
				}
			});
		}

		function showToast(type, message) {
			const container = document.getElementById('toast-container');
			const toast = document.createElement('div');
			toast.className = `toast align-items-center text-bg-${type} border-0`;
			toast.setAttribute('role', 'alert');
			toast.innerHTML = `<div class="d-flex"><div class="toast-body">${message}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
			container.appendChild(toast);
			const bsToast = new bootstrap.Toast(toast, {delay: 3000});
			bsToast.show();
			toast.addEventListener('hidden.bs.toast', () => toast.remove());
		}

		function setButtonLoading(btn, loading) {
			const icon = btn.querySelector('i');
			if (loading) {
				btn.disabled = true;
				icon.className = 'bi bi-arrow-repeat spin-icon';
			} else {
				btn.disabled = false;
				icon.className = icon.dataset.originalClass || 'bi bi-check-lg';
			}
		}

		document.querySelectorAll('form[id^="form-"]').forEach(form => {
			const btn = document.querySelector(`button[type="submit"][form="${form.id}"]`);
			const icon = btn.querySelector('i');
			icon.dataset.originalClass = icon.className;

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				setButtonLoading(btn, true);
				try {
					const res = await axios.post('/manage/api/holiday/update', new FormData(form));
					if (res.data.success) {
						showToast('success', 'Holiday updated.');
					}
				} catch (err) {
					const errors = err.response?.data?.errors;
					showToast('danger', errors ? errors.join(', ') : 'Failed to update holiday.');
				} finally {
					setButtonLoading(btn, false);
				}
			});
		});

		const createForm = document.getElementById('create');
		const createBtn = document.querySelector('button[type="submit"][form="create"]');
		const createIcon = createBtn.querySelector('i');
		createIcon.dataset.originalClass = createIcon.className;

		createForm.addEventListener('submit', async (e) => {
			e.preventDefault();
			setButtonLoading(createBtn, true);
			try {
				const res = await axios.post('/manage/api/holiday', new FormData(createForm));
				if (res.data.success) {
					showToast('success', res.data.message);
					createForm.reset();
				}
			} catch (err) {
				const errors = err.response?.data?.errors;
				showToast('danger', errors ? errors.join(', ') : 'Failed to create holiday.');
			} finally {
				setButtonLoading(createBtn, false);
			}
		});

		document.querySelectorAll('.btn-generate-desc').forEach(btn => {
			btn.addEventListener('click', async () => {
				const target = document.getElementById(btn.dataset.target);
				const nameEl = document.getElementById(btn.dataset.nameSource);
				const name = nameEl ? nameEl.value.trim() : '';

				let month, day;
				if (btn.dataset.monthSource) {
					month = document.getElementById(btn.dataset.monthSource)?.value;
					day = document.getElementById(btn.dataset.daySource)?.value;
				} else {
					month = btn.dataset.month;
					day = btn.dataset.day;
				}

				if (!name || !month || !day) {
					alert('Fill in day, month and name first.');
					return;
				}

				const icon = btn.querySelector('i');
				icon.className = 'bi bi-arrow-repeat spin-icon';
				btn.disabled = true;

				try {
					const res = await axios.post('/manage/api/generate', {
						type: 'description_pl',
						day: parseInt(day),
						month: parseInt(month),
						name,
					});
					if (res.data.error) {
						alert(res.data.error);
					} else {
						target.value = res.data.result;
					}
				} catch (e) {
					alert('Failed to generate description.');
				} finally {
					icon.className = 'bi bi-stars';
					btn.disabled = false;
				}
			});
		});
		});
	</script>
{% endblock %}
