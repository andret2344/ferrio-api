{% extends 'base.html.twig' %}
{% block title %}Polls — Ferrio Admin{% endblock %}
{% block body %}
	{% set toolbar_html %}
		<a href="{{ path('manage_polls_new') }}" class="btn btn-sm btn-outline-light">+ New Poll</a>
	{% endset %}
	<main class='section-manage-main'>
		{% include 'components/topbar.html.twig' with {toolbar: toolbar_html} %}
		<div class='manage-content'>
			<h2 class='manage-page-title'>Polls</h2>
			<div class='table-responsive'>
				<table class="table table-dark table-striped table-hover align-middle">
					<thead>
					<tr>
						<th>#</th>
						<th>Name</th>
						<th>Question</th>
						<th>Start</th>
						<th>End</th>
						<th>Active</th>
						<th>Votes</th>
						<th></th>
					</tr>
					</thead>
					<tbody>
					{% for poll in polls %}
						<tr>
							<td>{{ poll.id }}</td>
							<td>{{ poll.name }}</td>
							<td>{{ poll.question }}</td>
							<td>{{ poll.start|date('Y-m-d H:i') }}</td>
							<td>{{ poll.end|date('Y-m-d H:i') }}</td>
							<td>{{ poll.active ? 'Yes' : 'No' }}</td>
							<td>{{ voteCounts[poll.id] ?? 0 }}</td>
							<td>
								<a
										href="{{ path('manage_polls_show', {id: poll.id}) }}"
										class="btn btn-sm btn-outline-light"
								>View</a></td>
						</tr>
					{% else %}
						<tr>
							<td colspan="8" class="text-center text-muted">No polls yet.</td>
						</tr>
					{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</main>
{% endblock %}
