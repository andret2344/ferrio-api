{% extends 'base.html.twig' %}
{% block title %}Poll Results — Ferrio Admin{% endblock %}
{% block body %}
	<main class='section-manage-main'>
		{% include 'components/topbar.html.twig' %}
		<div class='manage-content'>
			<h2 class='manage-page-title'>{{ poll.name }}</h2>
			<p class="text-muted">{{ poll.question }}</p>
			<p>
				<strong>Period:</strong> {{ poll.start|date('Y-m-d H:i') }} → {{ poll.end|date('Y-m-d H:i') }}
				&nbsp;|&nbsp;
				<strong>Active:</strong> {{ poll.active ? 'Yes' : 'No' }}
				&nbsp;|&nbsp;
				<strong>Total votes:</strong> {{ total }}
			</p>
			<div class='table-responsive' style="max-width: 600px">
				<table class="table table-dark table-striped table-hover align-middle">
					<thead>
					<tr>
						<th>#</th>
						<th>Option</th>
						<th>Votes</th>
						<th>%</th>
					</tr>
					</thead>
					<tbody>
					{% for option in poll.options %}
						{% set optionCount = counts[option.id] ?? 0 %}
						{% set pct = total > 0 ? ((optionCount / total) * 100)|round(1) : 0 %}
						<tr>
							<td>{{ option.id }}</td>
							<td>{{ option.text }}</td>
							<td>{{ optionCount }}</td>
							<td>{{ pct }}%</td>
						</tr>
					{% endfor %}
					</tbody>
				</table>
			</div>
		</div>
	</main>
{% endblock %}
