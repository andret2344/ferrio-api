{% extends 'base.html.twig' %}
{% block body %}
	<main class='section-manage-main'>
		{% include 'components/topbar.html.twig' %}
		<div class='manage-content'>
			<h2 class='manage-page-title'>User Reports</h2>

			<ul class='nav nav-tabs reports-tabs' id='reportsTabs'>
				<li class='nav-item'>
					<button
							class='nav-link active'
							id='fixed-suggestions-tab'
							data-bs-toggle='tab'
							data-bs-target='#fixed-suggestions'
							type='button'
					>Fixed Suggestions
					</button>
				</li>
				<li class='nav-item'>
					<button
							class='nav-link'
							id='floating-suggestions-tab'
							data-bs-toggle='tab'
							data-bs-target='#floating-suggestions'
							type='button'
					>Floating Suggestions
					</button>
				</li>
				<li class='nav-item'>
					<button
							class='nav-link'
							id='fixed-errors-tab'
							data-bs-toggle='tab'
							data-bs-target='#fixed-errors'
							type='button'
					>Fixed Errors
					</button>
				</li>
				<li class='nav-item'>
					<button
							class='nav-link'
							id='floating-errors-tab'
							data-bs-toggle='tab'
							data-bs-target='#floating-errors'
							type='button'
					>Floating Errors
					</button>
				</li>
			</ul>

			<div class='tab-content mt-3' id='reportsTabContent'>
				{# Fixed Suggestions #}
				<div class='tab-pane fade show active' id='fixed-suggestions'>
					<div class='report-count'>{{ fixedSuggestions|length }} {{ fixedSuggestions|length == 1 ? 'entry' : 'entries' }}</div>
					{% if fixedSuggestions is empty %}
						<div class='text-center text-muted py-5'>No fixed holiday suggestions.</div>
					{% else %}
						<div class='table-responsive'>
							<table class='table table-dark table-striped table-hover align-middle'>
								<thead>
								<tr>
									<th>ID</th>
									<th>Name</th>
									<th>Date</th>
									<th>Description</th>
									<th>Country</th>
									<th>State</th>
									<th>Reported</th>
									<th>User</th>
									<th></th>
								</tr>
								</thead>
								<tbody>
								{% for s in fixedSuggestions %}
									<tr data-report-row data-kind='fixed_suggestion' data-id='{{ s.id }}'>
										<td>{{ s.id }}</td>
										<td>{{ s.name }}</td>
										<td>{{ '%02d.%02d'|format(s.day, s.month) }}</td>
										<td class='text-truncate' style='max-width: 250px;'>{{ s.description }}</td>
										<td>{{ s.country ? s.country.isoCode : '-' }}</td>
										<td>
											<span class='state-cell'>
												<span class='badge report-state report-state-{{ s.reportState.value|lower }}' data-role='state-badge'>
													{{ s.reportState.value }}
												</span>
												<button type='button' class='btn btn-comment-icon {{ s.comment ? '' : 'd-none' }}'
														data-role='comment-popover'
														data-bs-toggle='popover'
														data-bs-trigger='focus'
														data-bs-placement='top'
														data-bs-title='Comment'
														data-bs-content='{{ s.comment ?? '' }}'
														tabindex='0'
														title='Show comment'>
													<i class='bi bi-chat-left-text-fill'></i>
												</button>
											</span>
										</td>
										<td>{{ s.datetime|date('Y-m-d H:i') }}</td>
										<td class='user-cell'>
											{% set u = users[s.userId] ?? null %}
											{% if u and (u.name or u.email) %}
												<div class='user-name'>{{ u.name ?? '-' }}</div>
												<div class='user-email'>{{ u.email ?? '-' }}</div>
											{% endif %}
											<div class='user-uid'>{{ s.userId }}</div>
										</td>
										<td>
											<button type='button' class='btn btn-moderate'
													data-bs-toggle='modal' data-bs-target='#moderateModal'
													data-kind='fixed_suggestion'
													data-id='{{ s.id }}'
													data-state='{{ s.reportState.value }}'
													data-comment='{{ s.comment ?? '' }}'
													title='Moderate'>
												<i class='bi bi-pencil-square'></i>
											</button>
										</td>
									</tr>
								{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>

				{# Floating Suggestions #}
				<div class='tab-pane fade' id='floating-suggestions'>
					<div class='report-count'>{{ floatingSuggestions|length }} {{ floatingSuggestions|length == 1 ? 'entry' : 'entries' }}</div>
					{% if floatingSuggestions is empty %}
						<div class='text-center text-muted py-5'>No floating holiday suggestions.</div>
					{% else %}
						<div class='table-responsive'>
							<table class='table table-dark table-striped table-hover align-middle'>
								<thead>
								<tr>
									<th>ID</th>
									<th>Name</th>
									<th>Date</th>
									<th>Description</th>
									<th>Country</th>
									<th>State</th>
									<th>Reported</th>
									<th>User</th>
									<th></th>
								</tr>
								</thead>
								<tbody>
								{% for s in floatingSuggestions %}
									<tr data-report-row data-kind='floating_suggestion' data-id='{{ s.id }}'>
										<td>{{ s.id }}</td>
										<td>{{ s.name }}</td>
										<td>{{ s.date }}</td>
										<td class='text-truncate' style='max-width: 250px;'>{{ s.description }}</td>
										<td>{{ s.country ? s.country.isoCode : '-' }}</td>
										<td>
											<span class='state-cell'>
												<span class='badge report-state report-state-{{ s.reportState.value|lower }}' data-role='state-badge'>
													{{ s.reportState.value }}
												</span>
												<button type='button' class='btn btn-comment-icon {{ s.comment ? '' : 'd-none' }}'
														data-role='comment-popover'
														data-bs-toggle='popover'
														data-bs-trigger='focus'
														data-bs-placement='top'
														data-bs-title='Comment'
														data-bs-content='{{ s.comment ?? '' }}'
														tabindex='0'
														title='Show comment'>
													<i class='bi bi-chat-left-text-fill'></i>
												</button>
											</span>
										</td>
										<td>{{ s.datetime|date('Y-m-d H:i') }}</td>
										<td class='user-cell'>
											{% set u = users[s.userId] ?? null %}
											{% if u and (u.name or u.email) %}
												<div class='user-name'>{{ u.name ?? '-' }}</div>
												<div class='user-email'>{{ u.email ?? '-' }}</div>
											{% endif %}
											<div class='user-uid'>{{ s.userId }}</div>
										</td>
										<td>
											<button type='button' class='btn btn-moderate'
													data-bs-toggle='modal' data-bs-target='#moderateModal'
													data-kind='floating_suggestion'
													data-id='{{ s.id }}'
													data-state='{{ s.reportState.value }}'
													data-comment='{{ s.comment ?? '' }}'
													title='Moderate'>
												<i class='bi bi-pencil-square'></i>
											</button>
										</td>
									</tr>
								{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>

				{# Fixed Errors #}
				<div class='tab-pane fade' id='fixed-errors'>
					<div class='report-count'>{{ fixedErrors|length }} {{ fixedErrors|length == 1 ? 'entry' : 'entries' }}</div>
					{% if fixedErrors is empty %}
						<div class='text-center text-muted py-5'>No fixed holiday error reports.</div>
					{% else %}
						<div class='table-responsive'>
							<table class='table table-dark table-striped table-hover align-middle'>
								<thead>
								<tr>
									<th>ID</th>
									<th>Metadata</th>
									<th>Language</th>
									<th>Type</th>
									<th>Description</th>
									<th>State</th>
									<th>Reported</th>
									<th>User</th>
									<th></th>
								</tr>
								</thead>
								<tbody>
								{% for e in fixedErrors %}
									<tr data-report-row data-kind='fixed_error' data-id='{{ e.id }}'>
										<td>{{ e.id }}</td>
										<td>{{ e.metadata ? e.metadata.id : '-' }}</td>
										<td>{{ e.language.code }}</td>
										<td>
											<span class='badge bg-light text-dark'>{{ e.reportType.value|lower|replace({'_': ' '})|capitalize }}</span>
										</td>
										<td
												class='text-truncate'
												style='max-width: 250px;'>
											{{ e.description ?? '-' }}
										</td>
										<td>
											<span class='state-cell'>
												<span class='badge report-state report-state-{{ e.reportState.value|lower }}' data-role='state-badge'>
													{{ e.reportState.value }}
												</span>
												<button type='button' class='btn btn-comment-icon {{ e.comment ? '' : 'd-none' }}'
														data-role='comment-popover'
														data-bs-toggle='popover'
														data-bs-trigger='focus'
														data-bs-placement='top'
														data-bs-title='Comment'
														data-bs-content='{{ e.comment ?? '' }}'
														tabindex='0'
														title='Show comment'>
													<i class='bi bi-chat-left-text-fill'></i>
												</button>
											</span>
										</td>
										<td>{{ e.datetime|date('Y-m-d H:i') }}</td>
										<td class='user-cell'>
											{% set u = users[e.userId] ?? null %}
											{% if u and (u.name or u.email) %}
												<div class='user-name'>{{ u.name ?? '-' }}</div>
												<div class='user-email'>{{ u.email ?? '-' }}</div>
											{% endif %}
											<div class='user-uid'>{{ e.userId }}</div>
										</td>
										<td>
											<button type='button' class='btn btn-moderate'
													data-bs-toggle='modal' data-bs-target='#moderateModal'
													data-kind='fixed_error'
													data-id='{{ e.id }}'
													data-state='{{ e.reportState.value }}'
													data-comment='{{ e.comment ?? '' }}'
													title='Moderate'>
												<i class='bi bi-pencil-square'></i>
											</button>
										</td>
									</tr>
								{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>

				{# Floating Errors #}
				<div class='tab-pane fade' id='floating-errors'>
					<div class='report-count'>{{ floatingErrors|length }} {{ floatingErrors|length == 1 ? 'entry' : 'entries' }}</div>
					{% if floatingErrors is empty %}
						<div class='text-center text-muted py-5'>No floating holiday error reports.</div>
					{% else %}
						<div class='table-responsive'>
							<table class='table table-dark table-striped table-hover align-middle'>
								<thead>
								<tr>
									<th>ID</th>
									<th>Metadata</th>
									<th>Language</th>
									<th>Type</th>
									<th>Description</th>
									<th>State</th>
									<th>Reported</th>
									<th>User</th>
									<th></th>
								</tr>
								</thead>
								<tbody>
								{% for e in floatingErrors %}
									<tr data-report-row data-kind='floating_error' data-id='{{ e.id }}'>
										<td>{{ e.id }}</td>
										<td>{{ e.metadata ? e.metadata.id : '-' }}</td>
										<td>{{ e.language.code }}</td>
										<td>
											<span class='badge bg-light text-dark'>{{ e.reportType.value|lower|replace({'_': ' '})|capitalize }}</span>
										</td>
										<td
												class='text-truncate'
												style='max-width: 250px;'>
											{{ e.description ?? '-' }}
										</td>
										<td>
											<span class='state-cell'>
												<span class='badge report-state report-state-{{ e.reportState.value|lower }}' data-role='state-badge'>
													{{ e.reportState.value }}
												</span>
												<button type='button' class='btn btn-comment-icon {{ e.comment ? '' : 'd-none' }}'
														data-role='comment-popover'
														data-bs-toggle='popover'
														data-bs-trigger='focus'
														data-bs-placement='top'
														data-bs-title='Comment'
														data-bs-content='{{ e.comment ?? '' }}'
														tabindex='0'
														title='Show comment'>
													<i class='bi bi-chat-left-text-fill'></i>
												</button>
											</span>
										</td>
										<td>{{ e.datetime|date('Y-m-d H:i') }}</td>
										<td class='user-cell'>
											{% set u = users[e.userId] ?? null %}
											{% if u and (u.name or u.email) %}
												<div class='user-name'>{{ u.name ?? '-' }}</div>
												<div class='user-email'>{{ u.email ?? '-' }}</div>
											{% endif %}
											<div class='user-uid'>{{ e.userId }}</div>
										</td>
										<td>
											<button type='button' class='btn btn-moderate'
													data-bs-toggle='modal' data-bs-target='#moderateModal'
													data-kind='floating_error'
													data-id='{{ e.id }}'
													data-state='{{ e.reportState.value }}'
													data-comment='{{ e.comment ?? '' }}'
													title='Moderate'>
												<i class='bi bi-pencil-square'></i>
											</button>
										</td>
									</tr>
								{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</main>

	<div class='modal fade' id='moderateModal' tabindex='-1' aria-labelledby='moderateModalLabel' aria-hidden='true'
		 data-moderate-url='{{ path('manage_reports_moderate') }}'>
		<div class='modal-dialog modal-dialog-centered'>
			<div class='modal-content'>
				<div class='modal-header'>
					<h5 class='modal-title' id='moderateModalLabel'>Moderate report</h5>
					<button type='button' class='btn-close' data-bs-dismiss='modal' aria-label='Close'></button>
				</div>
				<div class='modal-body'>
					<form id='moderateForm'>
						<input type='hidden' name='kind' id='moderateKind'>
						<input type='hidden' name='id' id='moderateId'>
						<div class='mb-3'>
							<label class='form-label' for='moderateStateToggle'>State</label>
							<div class='dropdown state-dropdown'>
								<button class='btn dropdown-toggle state-dropdown-toggle' type='button'
										id='moderateStateToggle' data-bs-toggle='dropdown' aria-expanded='false'>
									<span class='badge report-state' data-role='state-toggle-badge'></span>
								</button>
								<ul class='dropdown-menu dropdown-menu-dark state-dropdown-menu' aria-labelledby='moderateStateToggle'>
									{% for state in report_states %}
										<li>
											<button type='button' class='dropdown-item' data-value='{{ state }}'>
												<span class='badge report-state report-state-{{ state|lower }}'>{{ state }}</span>
											</button>
										</li>
									{% endfor %}
								</ul>
								<input type='hidden' id='moderateState' name='report_state'>
							</div>
						</div>
						<div class='mb-3'>
							<label for='moderateComment' class='form-label'>Comment</label>
							<textarea class='form-control' id='moderateComment' name='comment' rows='4' placeholder='Optional note (e.g. "duplicate of #42")'></textarea>
						</div>
						<div class='alert alert-danger d-none' id='moderateError' role='alert'></div>
					</form>
				</div>
				<div class='modal-footer'>
					<button type='button' class='btn btn-outline-light' data-bs-dismiss='modal'>Cancel</button>
					<button type='button' class='btn btn-primary' id='moderateSave'>
						<i class='bi bi-check-lg me-1'></i>Save
					</button>
				</div>
			</div>
		</div>
	</div>

{% endblock %}
